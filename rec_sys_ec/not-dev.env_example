S3_BUCKET_NAME=# имя бакета S3
AWS_ACCESS_KEY_ID=# AWS_ACCESS_KEY для S3
AWS_SECRET_ACCESS_KEY=# AWS_SECRET_ACCESS для S3
RECOMMENDATIONS_HOST=http://recommendation_service # хост сервиса рекомендаций при запуске в докере
RECOMMENDATIONS_PORT=8020 # внутренний порт сервиса рекомендаций в докере
RECOMMENDATIONS_OUT_PORT=8020 # внешний порт сервиса рекомендаций в докере
EVENTS_HOST=http://events_service # хост сервиса регистрации действий пользователя при запуске в докере
EVENTS_PORT=8010 # внутренний порт сервиса регистрации действий пользователя в докере
EVENTS_OUT_PORT=8010 # внешний порт сервиса регистрации действий пользователя в докере
AUTHOR=# Имя автора для поднятия докера
GRAFANA_USER=# имя пользователя для входа в Графану
GRAFANA_PASS=# Пароль для входа в Графану
